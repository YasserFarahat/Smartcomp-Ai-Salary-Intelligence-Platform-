from datetime import datetime


def calculate_prorated_salary(base_salary, worked_days, payroll_days):
    return round((worked_days / payroll_days) * base_salary, 2)


def calculate_deductions(absent_days, deduction_per_day):
    return absent_days * deduction_per_day


def calculate_net_salary(base_salary, bonuses, deductions):
    return base_salary + bonuses - deductions
