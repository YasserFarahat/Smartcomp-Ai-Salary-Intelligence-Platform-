def detect_payroll_anomalies(employee_data):
    alerts = []

    if employee_data["overtime_hours"] > 80:
        alerts.append("Excess overtime detected")

    if employee_data["salary_increase_percent"] > 30:
        alerts.append("Abnormal salary increase")

    if employee_data["deductions"] < 0:
        alerts.append("Negative deductions error")

    return alerts
