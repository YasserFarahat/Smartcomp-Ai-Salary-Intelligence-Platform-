FastAPI Main Entry
main.py
from fastapi import FastAPI
from fastapi.middleware.cors import CORSMiddleware

app = FastAPI(title="SmartComp AI")

app.add_middleware(
    CORSMiddleware,
    allow_origins=["*"],
    allow_credentials=True,
    allow_methods=["*"],
    allow_headers=["*"],
)

@app.get("/")
def home():
    return {
        "status": "running",
        "app": "SmartComp AI"
    }
Payroll Calculation Service
def calculate_salary(base_salary, worked_days, payroll_days):
    return (worked_days / payroll_days) * base_salary
AI Risk Engine Example
def detect_salary_risk(old_salary, new_salary):
    increase = ((new_salary - old_salary) / old_salary) * 100

    if increase > 30:
        return {
            "risk": True,
            "message": "Abnormal salary increase detected"
        }

    return {
        "risk": False
    }
